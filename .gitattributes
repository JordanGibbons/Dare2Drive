# Force LF line endings for shell scripts and Docker files regardless of OS
*.sh        text eol=lf
Dockerfile* text eol=lf
*.toml      text eol=lf
*.py        text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.ini       text eol=lf
*.cfg       text eol=lf
*.mako      text eol=lf
.env*       text eol=lf
