# --- Managed via Infisical ---
DISCORD_TOKEN=your-discord-bot-token        # managed via Infisical
API_SECRET_KEY=change-me-to-a-random-key    # managed via Infisical
INFISICAL_TOKEN=                            # managed via Infisical — machine identity token
INFISICAL_PROJECT_ID=                       # managed via Infisical — project UUID
INFISICAL_ENVIRONMENT=dev                   # managed via Infisical — dev | staging | production

# --- Injected by Railway (or docker-compose for local dev) ---
DATABASE_URL=postgresql+asyncpg://dare2drive:dare2drive@db:5432/dare2drive   # injected by Railway
REDIS_URL=redis://redis:6379/0                                               # injected by Railway
DISCORD_GUILD_ID=000000000000000000         # injected by Railway — your test guild snowflake

# --- App config ---
LOG_LEVEL=INFO                              # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                             # text | json — use json in production (Fluent Bit)
ENVIRONMENT=development                     # development | production

# --- Monitoring ---
# Phone alerts via ntfy.sh (free iOS/Android app — ntfy.sh or self-hosted)
# Pick a long, random private topic name so only your team can subscribe.
NTFY_TOPIC=dare2drive-alerts-changeme       # e.g. dare2drive-xK9mP3Qq8r
NTFY_URL=https://ntfy.sh                    # or your self-hosted ntfy instance
NTFY_TOKEN=                                 # bearer token if your ntfy instance requires auth

# Grafana admin credentials (change before first run)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-in-prod
